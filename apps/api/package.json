{
  "name": "@kahf/api",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase-admin": "^13.4.0",
    "google-logging-utils": "^1.1.3",
    "semver": "^7.7.2",
    "zod": "^3.24.3"
  },
  "scripts": {
    "prepare:runtime": "npm run build:runtime",
    "start": "npm run prepare:runtime && node dist/main.js",
    "start:dev": "npm run prepare:runtime && node --watch dist/main.js",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "build:runtime": "node ./scripts/build-runtime.mjs"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "tsx": "^4.19.3"
  }
}
