{
  "name": "kahf-wealth",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "test": "vitest run",
    "lint": "eslint apps packages --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc -p tsconfig.repo.json --noEmit",
    "build": "tsc -p tsconfig.repo.json --noEmit"
  },
  "overrides": {
    "react": "19.0.0",
    "react-native": "0.79.6",
    "@react-native/virtualized-lists": "0.79.6"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "debug": "^4.4.3",
    "eslint": "^9.24.0",
    "mime-db": "^1.54.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
